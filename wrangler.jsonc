{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "jinx",
	"main": "worker/src/index.js",
	"compatibility_date": "2026-05-11",
	"observability": {
		"enabled": true
	},
	"compatibility_flags": [
		"nodejs_compat"
	],
	"vars": {
		"GITHUB_REPO": "rladies/jinx"
	},
	"ai": {
		"binding": "AI"
	},
	"vectorize": [
		{
			"binding": "RAG_INDEX",
			"index_name": "rladies-content"
		},
		{
			"binding": "VECTORIZE",
			"index_name": "rladies-content",
			"remote": true
		}
	],
	"kv_namespaces": [
		{
			"binding": "SLACK_TOKENS",
			"id": "5614aacb7982413e807c2ae2126a4b3b"
		},
		{
			"binding": "AIRTABLE_BASES",
			"id": "698b7f8a6f214bf9ad9ecfaa839638f4"
		},
		{
			"binding": "SHORT_LINKS",
			"id": "22243a634eea4065a5572870c204c75f"
		}
	],
	// Anonymous question-improvement log (see worker/src/question-log.js).
	// Provisioned on the RLadies+ account; schema in worker/migrations. To
	// re-apply migrations: `wrangler d1 migrations apply jinx-question-log --remote`.
	"d1_databases": [
		{
			"binding": "QUESTION_LOG",
			"database_name": "jinx-question-log",
			"database_id": "4500d886-2593-44f9-9a01-d38cfa26e8dc",
			"migrations_dir": "worker/migrations"
		}
	],
	// Scheduled jobs (see the scheduled() handler in worker/src/index.js):
	//   17 3 * * *  — daily purge of question-log rows past 180 days
	//   0 9 * * 1   — weekly question-gap digest to the global-team channel
	"triggers": {
		"crons": [
			"17 3 * * *",
			"0 9 * * 1"
		]
	},
	// Requires a DNS record for l.rladies.org (proxied through Cloudflare) on
	// the rladies.org zone -- the route alone won't receive traffic without it.
	"routes": [
		{
			"pattern": "l.rladies.org/*",
			"zone_name": "rladies.org"
		}
	],
	// Adding `routes` above flips wrangler's default for this to false, which
	// silently took down the primary https://jinx.rladies.workers.dev URL that
	// Slack's slash-command/event-subscription config points at. Keep this
	// explicit so a future `routes` addition can't repeat that outage.
	"workers_dev": true
}
