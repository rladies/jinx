{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Event",
  "type": "object",
  "required": ["title", "date", "url", "source", "chapter"],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "url": {
      "type": "string",
      "format": "uri"
    },
    "rsvp_count": {
      "type": "integer",
      "minimum": 0
    },
    "source": {
      "type": "string",
      "enum": ["meetup"]
    },
    "chapter": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false
}
