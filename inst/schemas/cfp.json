{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CFP",
  "type": "object",
  "required": ["conference", "deadline", "url"],
  "properties": {
    "conference": {
      "type": "string",
      "minLength": 1
    },
    "deadline": {
      "type": "string",
      "format": "date"
    },
    "url": {
      "type": "string",
      "format": "uri"
    },
    "topics": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": ["open", "closed", "submitted"]
    }
  },
  "additionalProperties": false
}
